# --- Safety (do not change defaults without a recorded human decision) ---
FORCE_PAPER_ONLY=true
REAL_TRADING_ENABLED=false

# --- Data ---
DATA_DIR=./data

# --- Paper state ---
PAPER_STATE_PATH=./paper_state.json
PAPER_STARTING_CASH=10000

# --- Shadow state ---
SHADOW_STATE_PATH=./shadow_state.json
# On Railway with a volume mounted at /mnt/data:
# SHADOW_STATE_PATH=/mnt/data/shadow_state.json

# --- Web ---
PORT=5060

# --- Optional dashboard auth ---
# If DASHBOARD_PASSWORD is set, "/" and "/api/status" require HTTP Basic Auth.
# Leave unset for open local/dev. "/health" is always public.
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=change_me
